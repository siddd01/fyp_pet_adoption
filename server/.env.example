# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=pet_adoption

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_key_here
STAFF_JWT_SECRET=your_staff_jwt_secret_key_here

# Khalti Payment Gateway
KHALTI_SECRET_KEY=your_khalti_live_secret_key_here
KHALTI_TEST_SECRET_KEY=your_khalti_test_secret_key_here
KHALTI_BASE_URL=https://khalti.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
